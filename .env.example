# ===========================================
# DOCKER-COMPOSE SERVICES (TimescaleDB)
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kairo
POSTGRES_EXTENSIONS=timescaledb
TIMESCALE_HOST=timescale
POSTGRES_PORT=5432

# Mosquitto (MQTT Broker)
# No authentication configured by default

# TimesFM Inference Service
TIMESFM_MODEL_PATH=/models/timesfm
TIMESFM_DEVICE=cpu
TIMESFM_CONTEXT_LENGTH=512
TIMESFM_FORECAST_LENGTH=128

# ClearML (MLOps platform)
CLEARML_API_HOST=http://localhost:8008
CLEARML_WEB_HOST=http://localhost:8080
CLEARML_FILES_HOST=http://localhost:8081
CLEARML_API_ACCESS_KEY=your-access-key
CLEARML_API_SECRET_KEY=your-secret-key
CLEARML_AGENT_UPDATE_VERSION=>=0.17.0
CLEARML_AGENT_DEFAULT_BASE_DOCKER=ubuntu:18.04

# Git credentials for ClearML agent (if needed)
GIT_USER=
GIT_PASS=

# ===========================================
# SUPABASE CLI SERVICES (Auth + Studio + Storage)
# ===========================================
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_STORAGE_ENDPOINT=127.0.0.1:54321
SUPABASE_STORAGE_ACCESS_KEY=xxx
SUPABASE_STORAGE_SECRET_KEY=xxx

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-anon-key

# ===========================================
# DEPRECATED - Docker Auth Service (removed)
# These variables are no longer used with Supabase CLI
# Kept for reference only - DO NOT USE
